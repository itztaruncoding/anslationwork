{
  "manifest_version": 3,
  "name": "Microphone Checker",
  "short_name": "Mic Checker",
  "version": "1.0.0",
  "description": "Professional microphone testing and diagnostics tool",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon16.png",
    "default_title": "Microphone Checker"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "microphone"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
